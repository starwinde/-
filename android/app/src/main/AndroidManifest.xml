<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Usage stats (PACKAGE_USAGE_STATS is a protected permission; user must grant via Settings) -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Exact alarms for daily settlement scheduling -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Foreground service for focus session tracking -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Accelerometer-based desk-away detection -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Battery optimization bypass (requested after user consent) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Blacklist matching requires enumerating installed packages -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Keep CPU alive during focus sessions -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Reschedule alarms after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- T5.21 방해 허용: 모든 강도에서 진동 사용 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- T5.21 방해 허용: 다른 앱 위에서 startActivity (홈 강제 이동) BAL 우회.
         사용자는 시스템 설정 "다른 앱 위에 표시"에서 직접 켜야 한다. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:label="routinemon"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Focus session foreground service stub (implementation in Phase 1) -->
        <service
            android:name=".service.FocusForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- T5.21 방해 허용: keeps the process alive while a schedule with
             disruption allowance is active so Dart Timer.periodic interventions
             fire reliably. -->
        <service
            android:name=".service.DisturbanceForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- 활성 일정 sticky 알림 (USB 알림 패턴) — 사용자가 swipe 로 못 지움.
             ScheduleSessionTrigger 가 일정 진입/종료 시 start/stop 호출. -->
        <service
            android:name=".service.ScheduleForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- T5.21 방해 허용 L3: DeviceAdminReceiver. force-lock policy only.
             User must grant device-admin in system settings via
             DisturbanceApi.requestDeviceAdmin(). -->
        <receiver
            android:name=".admin.RoutinemonDeviceAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
